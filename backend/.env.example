# HazardAlert — Environment Variables Reference
# Copy this to .env and fill in your real values
# NEVER commit .env to git

# ── Server ───────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database (MySQL) ─────────────────────────────
DB_HOST=your_db_host
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=hazard_reporting_db
DB_PORT=3306

# ── Frontend URL (set to your deployed frontend URL) ──
FRONTEND_URL=https://your-app.up.railway.app

# ── AI & External APIs ───────────────────────────
# Get Gemini API key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Get OpenWeather key: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ── Auto-Escalation Settings ─────────────────────
ESCALATION_DAY_1=7
ESCALATION_DAY_2=15
ESCALATION_DAY_3=30
